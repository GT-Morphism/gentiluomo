# DOCS: https://docs.directus.io/self-hosted/config-options.html
# NOTE: Variables referenced by `${}` are pulled in by your .env file
# NOTE: After updating any environment variable, you need to restart your docker container.

# GENERAL (https://docs.directus.io/self-hosted/config-options.html#general)
PUBLIC_URL="${PUBLIC_DIRECTUS_API_URL}"

# DATABASE (https://docs.directus.io/self-hosted/config-options.html#database)
DB_CLIENT=""
DB_HOST=""
DB_PORT=""
DB_DATABASE="${POSTGRES_DB}"
DB_USER="${POSTGRES_USER}"
DB_PASSWORD="${POSTGRES_PASSWORD}"

# CACHE (https://docs.directus.io/self-hosted/config-options.html#cache)
CACHE_ENABLED=""
CACHE_AUTO_PURGE=""
CACHE_STORE=""

# REDIS (https://docs.directus.io/self-hosted/config-options.html#redis)
REDIS=""

# ADMIN ACCOUNT (https://docs.directus.io/self-hosted/config-options.html#admin-account)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# SECURITY (https://docs.directus.io/self-hosted/config-options.html#security)
SECRET=""
ACCESS_TOKEN_TTL=

# FILE STORAGE (https://docs.directus.io/self-hosted/config-options.html#file-storage)
STORAGE_LOCATIONS=""
STORAGE_<LOCATION>_DRIVER=""
STORAGE_<LOCATION>_ROOT=""
## FILE STORAGE S3 (https://docs.directus.io/self-hosted/config-options.html#s3-s3)
STORAGE_<LOCATION>_KEY=""
STORAGE_<LOCATION>_SECRET=""
STORAGE_<LOCATION>_BUCKET=""
STORAGE_<LOCATION>_REGION=""
STORAGE_<LOCATION>_ENDPOINT=""
